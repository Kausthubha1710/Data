@Library('cibdbdbce-lib')_

// ---------------------------------------------------------------------------
// getEnvironments() filters the database dropdown based on which Jenkins
// instance is running the build, preventing cross-environment deployments.
//
// Dev Jenkins  URL contains  "cibdbdbce-dev-cibdbdbce"  → DEV, TEST, UAT only
// Prod Jenkins URL contains  "cibdbdbce-aps-cibdbdbce"  → STG, PRD only
// ---------------------------------------------------------------------------
def getEnvironments() {
    def ECOSYSTEM = "cibdbdbce"   // BUG FIX #1: was 'def ECOSYSTEM "cibdbdbce"' — missing '=' assignment operator
    if (env.JENKINS_URL.contains(ECOSYSTEM.toLowerCase() + "-dev-" + ECOSYSTEM.toLowerCase()))
        return ["DEV", "TEST", "UAT"]
    if (env.JENKINS_URL.contains(ECOSYSTEM.toLowerCase() + "-aps-" + ECOSYSTEM.toLowerCase()))
        return ["STG", "PRD"]
    return []
}

liquibasePipeline {
    ecosystem           = 'pilothouse'
    envList             = getEnvironments()
    // INTEGRATION: envList is now populated by getEnvironments() instead of a
