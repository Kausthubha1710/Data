def getCredentialForEnv(String environment) {

    def credentialMap = [
        "DEV" : "niowcis",
        "TEST": "niowcis",
        "UAT" : "niowcis",

        "STG" : "evcwef",
        "PRD" : "evcwef"
    ]

    return credentialMap[environment]
}
✅ Step 2 — Initialize Stage (IMPORTANT CHANGE)

Modify Initialize stage:

stage('Initialize') {
    steps {
        script {

            checkout scm

            // Get environments dynamically
            ENVIRONMENTS = getEnvironments()

            if (!ENVIRONMENTS) {
                error "No environments detected"
            }

            // Select first environment (or parameter later)
            SELECTED_ENV = ENVIRONMENTS[0]

            // ✅ Resolve credential automatically
            DB_CREDENTIAL_ID = getCredentialForEnv(SELECTED_ENV)

            if (!DB_CREDENTIAL_ID) {
                error "No credential mapped for ${SELECTED_ENV}"
            }

            echo "Environment: ${SELECTED_ENV}"
            echo "Credential: ${DB_CREDENTIAL_ID}"
        }
    }
}
