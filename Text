def credentialMap = pipelineParams.dbCredentialMap

if (!credentialMap) {
    error "dbCredentialMap not defined in Jenkinsfile"
}

def selectedEnv = params.database

if (!credentialMap.containsKey(selectedEnv)) {
    error "No credential mapped for environment: ${selectedEnv}"
}

def accountId = credentialMap[selectedEnv]

echo "Environment '${selectedEnv}' mapped to Credential '${accountId}'"




def getDBEnvironments(ecosystem, envList=null) {

    def environments = getEnvironments(ecosystem, envList)

    if (!environments || environments.isEmpty()) {
        error "No environments available for this Jenkins instance"
    }

    return String.join("\n", environments)
}



