def call(body) {
    def pipelineParams = [:]
    body.resolveStrategy = Closure.DELEGATE_FIRST
    body.delegate = pipelineParams
    body()

    def buildNo = currentBuild.displayName
    currentBuild.displayName += ">${pipelineParams.ecosystem}>${params.database}>${params.action}"
    currentBuild.description = "Build: ${buildNo} | ${params.operation}"

    def cyberarkCert  = pipelineParams.cyberarkCertFile
    def cyberarkKey   = pipelineParams.cyberarkKeyFile
    def cyberarkCA    = pipelineParams.cyberarkCAFile
    def cyberarkAppId = pipelineParams.cyberarkAppId
    def safeId        = pipelineParams.cyberarkSafe
    def region        = pipelineParams.region == null ? "EMEA" : pipelineParams.region

    if (env.JENKINS_URL.contains("-aps-")) {
        cyberarkCert  = pipelineParams.cyberarkCertFileProd
        cyberarkKey   = pipelineParams.cyberarkKeyFileProd
        cyberarkAppId = params.cyberarkAppIProd
        safeId        = pipelineParams.cyberarkSafeProd
    }

    timestamps {
        ansiColor('xterm') {
            def agentName = "bnpp-buildtools"
            if (pipelineParams.agent != null) {
                agentName = pipelineParams.agent
            }

            node(agentName) {
                withEnv(['LOG_APP=' + pipelineParams.ecosystem,
                         'LOG_ENV=' + params.database]) {

                    try {
                        stage('Initialize') {
                            initializeSqlPipelineParameters(pipelineParams.ecosystem, pipelineParams.envList)
                        }

                        // -------------------------------------------------------
                        // GUARD: Stop here on first run (parameter registration).
                        // params.database is null/empty until the user has
                        // actually filled in the form and clicked Build.
                        // -------------------------------------------------------
                        if (!params.database || params.database == 'NONE') {
                            echo "Parameters registered. Please trigger the build again with your selections."
                            currentBuild.result = 'NOT_BUILT'
                            return
                        }

                        // Only reaches here on a real triggered build
                        def credentialMap = pipelineParams.dbCredentialMap

                        if (!credentialMap) {
                            error "dbCredentialMap not defined in Jenkinsfile"
                        }

                        if (!credentialMap.containsKey(params.database)) {
                            error "No credential mapped for environment: ${params.database}"
                        }

                        def accountId = credentialMap[params.database]
                        echo "Environment '${params.database}' mapped to Credential '${accountId}'"

                        stage('Checkout') {
                            checkout scm
                            hook.loadExternalHooks()
                            hook('postCheckout', this)
                        }

                        stage('Database Change Execution') {
                            try {
                                def changefile = params.changelogfile ?: pipelineParams.dbchangelogfile

                                def fetch_secret    = cyberarkSecret(cyberarkCert, cyberarkKey, cyberarkCA, region, safeId, cyberarkAppId, accountId)
                                def cyberark_username = fetch_secret['UserName'].toString()
                                def cyberark_password = fetch_secret['Content'].toString()

                                echo "The changelogfile to be executed is ------>>>>>>>>>>>>> ${changefile}"

                                wrap([$class: 'MaskPasswordsBuildWrapper',
                                      varPasswordPairs: [
                                          [password: cyberark_password, var: 'PASSWORD_SECRET'],
                                          [password: cyberark_username, var: 'USERNAME_SECRET']
                                      ]]) {
                                    executeliquibase(pipelineParams.ecosystem, params.action, params.operation, params.database, params.tag_value, params.count, params.date, params.tag, changefile, cyberark_username, cyberark_password)
                                }
                            } catch (Exception e) {
                                currentBuild.result = 'FAILURE'
                                echo "Execution failed"
                                throw e
                            }
                        }

                    } catch (Exception e) {
                        currentBuild.result = 'FAILURE'
                        throw e
                    } finally {
                        stage('Terminate') {
                            notifyUser(pipelineParams.ecosystem, params.database, pipelineParams.emailto)
                            echo "End of the Pipeline"
                        }
                    }
                }
            }
        }
    }
}
